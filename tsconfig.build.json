// Specialized tsconfig to only compile .ts-files in the src dir
{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"allowJs": false,
		"checkJs": false,
		"noEmit": false,
		"declaration": false,
		"rootDir": "./src",
		"outDir": "./build"
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/**/*.test.ts"]
}
